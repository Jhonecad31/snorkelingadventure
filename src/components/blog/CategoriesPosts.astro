---
import { replaceHtmlEntities } from "@/utils/functions";
import { getCategories } from "@/services/wp";

const categories = await getCategories();

interface Props {
    pathCurrent?: string;
}

interface Category {
    name: string;
    slug: string;
}

const { pathCurrent = "blog-home" } = Astro.props;
---
<ul class="space-x-4 my-2 flex md:flex-wrap md:justify-center md:items-center overflow-x-scroll md:overflow-auto" style="scrollbar-width: none;">
    <li class="text-sm">
        <a
            href="/blog/"
            class={`inline-flex px-6 md:px-8 py-2 md:py-3 rounded-full hover:opacity-80 ${pathCurrent === "blog-home" ? "bg-linear-to-br from-sky-700 via-sky-400 to-cyan-500 font-semibold text-white" : "bg-gray-100 hover:bg-gray-200"} transition-colors duration-300 shadow-md my-2 whitespace-nowrap`}
        >
            All Posts
        </a>
    </li>
    {
        categories.map((cat: Category) => (
                <li class="text-sm">
                    <a
                        href={`/blog/category/${cat.slug}/`}
                        class={`inline-flex px-6 md:px-8 py-2 md:py-3 rounded-full hover:opacity-80 ${pathCurrent === cat.slug ? "bg-linear-to-br from-sky-700 via-sky-400 to-cyan-500 font-semibold text-white" : "bg-gray-100 hover:bg-gray-200"} transition-colors duration-300 shadow-md my-2 whitespace-nowrap`}
                    >
                        {replaceHtmlEntities(cat.name)}
                    </a>
                </li>
        ))
    }
</ul>
