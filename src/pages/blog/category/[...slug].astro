---
export const prerender = false;
import { getCategoryBySlug, getPostsByCategoryByPageValidation } from "@/services/wp";
import { replaceHtmlEntities } from "@/utils/functions";
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlockContainer from "@/components/global/BlockContainer.astro";
import BlogCategoryCard from "@/components/blog/BlogCategoryCard.astro";
import SkeletonBlogCard from "@/components/blog/SkeletonBlogCard.astro";
import PaginationCategoryPosts from "@/components/blog/PaginationCategoryPosts.astro";
import HeroGradient from "@/components/sections/HeroGradient.astro";
import CategoriesPosts from "@/components/blog/CategoriesPosts.astro";

const { slug } = Astro.params;

const slugParts = slug?.split("/page/");
const slugPartCategory = slugParts?.[0]; // Slug de la categoría
const pageNumber = parseInt(slugParts?.[1] ?? "1", 10); // Número de página (por defecto 1)

const { id, name, slugCategory, totalPosts } = await getCategoryBySlug(slugPartCategory as string);
const existsPage = await getPostsByCategoryByPageValidation(id ?? null, { page: pageNumber });

if (!id || !existsPage) {
    return new Response(null, { status: 404 });
}
const seoMetaDatos = {
    title: pageNumber > 1 ? `${replaceHtmlEntities(name)} Archives - Page ${pageNumber} - Snorkeling Adventure` : `${replaceHtmlEntities(name)} Archives - Snorkeling Adventure`,
    description: pageNumber > 1 ? `Read the articles in our ${replaceHtmlEntities(name)} Archives for your next trip to Puerto Morelos and Riviera Maya. Page ${pageNumber}.` : `Read the articles in our ${replaceHtmlEntities(name)} Archives for your next trip to Puerto Morelos and Riviera Maya.`,
};

const dataPosts = {
    title: pageNumber > 1 ? `${replaceHtmlEntities(name)} Archives - Page ${pageNumber}` : `${replaceHtmlEntities(name)} Archives`,
    description: id != null ? `Read the articles in our ${replaceHtmlEntities(name)} Archives for your next trip to Puerto Morelos and Riviera Maya.` : "",
};
---

<BaseLayout seo={seoMetaDatos} offI18n={true}>
    <HeroGradient
        title={dataPosts.title}
        text={dataPosts.description}
    />
    <BlockContainer>
        <!-- Categories -->
        <div class="w-full md:w-4/5 mx-auto">
            <p class="text-lg mb-10 text-center! font-semibold">
                Explore Categories
            </p>
            <CategoriesPosts server:defer pathCurrent={slugPartCategory}>
                <ul class="space-x-4 space-y-2 my-2 flex md:flex-wrap md:justify-center md:items-center overflow-x-scroll md:overflow-auto animate-pulse" style="scrollbar-width: none;" slot="fallback">
                    {Array.from({ length: 7 }).map(() => (
                        <li class="px-20 md:px-0 w-60 h-10 rounded-full bg-gray-200"></li>
                    ))}
                </ul>
            </CategoriesPosts>
        </div>
        <!-- Posts -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mt-10">
            <BlogCategoryCard
                server:defer
                idCategory={id}
                page={pageNumber}
            >
                {Array.from({ length: 12 }).map(() => (
                    <SkeletonBlogCard slot="fallback" />
                ))}
            </BlogCategoryCard>
        </div>
        <!-- Pagination -->
        <div class="mt-10">
            <PaginationCategoryPosts
                server:defer
                totalPosts={totalPosts}
                slugCategory={slugCategory}
                currentPage={pageNumber}
            />
        </div>
    </BlockContainer>
</BaseLayout>
