---
export const prerender = false;
import { getPostsByPageValidation } from "@/services/wp";
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlockContainer from "@/components/global/BlockContainer.astro";
import BlogCard from "@/components/blog/BlogCard.astro";
import SkeletonBlogCard from "@/components/blog/SkeletonBlogCard.astro";
import PaginationPosts from "@/components/blog/PaginationPosts.astro";
import HeroGradient from "@/components/sections/HeroGradient.astro";
import CategoriesPosts from "@/components/blog/CategoriesPosts.astro";

const { page } = Astro.params;
const pageNumber = parseInt(page as unknown as string, 10);
const existsPage = await getPostsByPageValidation({ page: pageNumber });

if (!existsPage) {
    return new Response(null, { status: 404 });
}

const seoMetaDatos = {
    title: `Explore Our Blog - Snorkeling Adventure - Page ${pageNumber}`,
    description: `Get more information in our Blog for your next trip to Cancun and Riviera Maya. Any doubt you have, we will offer the answer. Page ${pageNumber}.`,
};

const dataPosts = {
    title: `Discover a World of Snorkeling Adventures in Puerto Morelos - Page ${pageNumber}`,
    description:
        "Get more information in our Blog for your next trip to Cancun and Riviera Maya. Any doubt you have, we will offer the answer.",
};
---

<BaseLayout seo={seoMetaDatos} offI18n={true}>
    <HeroGradient title={dataPosts.title} text={dataPosts.description} />
    <BlockContainer>
        <!-- Categories -->
        <div class="w-full md:w-4/5 mx-auto">
            <p class="text-lg mb-10 text-center! font-semibold">
                Explore Categories
            </p>
            <CategoriesPosts server:defer pathCurrent="blog-home">
                <ul class="space-x-4 space-y-2 my-2 flex md:flex-wrap md:justify-center md:items-center overflow-x-scroll md:overflow-auto animate-pulse" style="scrollbar-width: none;" slot="fallback">
                    {Array.from({ length: 7 }).map(() => (
                        <li class="px-20 md:px-0 w-60 h-10 rounded-full bg-gray-200"></li>
                    ))}
                </ul>
            </CategoriesPosts>
        </div>
        <!-- Posts -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mt-10">
            <BlogCard server:defer page={pageNumber}>
                {
                    Array.from({ length: 12 }).map(() => (
                        <SkeletonBlogCard slot="fallback" />
                    ))
                }
            </BlogCard>
        </div>
        <!-- Pagination -->
        <div class="mt-10">
            <PaginationPosts server:defer currentPage={pageNumber} />
        </div>
    </BlockContainer>
</BaseLayout>
